<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Required_fields_fechaDeEnvio</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Status, &quot;Accepted&quot;),
  ISCHANGED(Status),
  OR(
    ISBLANK(ATV_NTS_FECHA_DE_ENVIO__c)
  )
)</errorConditionFormula>
    <errorDisplayField>ATV_NTS_FECHA_DE_ENVIO__c</errorDisplayField>
    <errorMessage>Para aceptar la cotización, completá: Fecha de envío.</errorMessage>
</ValidationRule>
