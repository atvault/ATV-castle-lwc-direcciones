<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Required_fields_Transporte</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Status, &quot;Accepted&quot;),
  ISCHANGED(Status),
  OR(
    ISPICKVAL(ATV_NTS_TRANSPORTE__c, &quot;&quot;)
  )
)</errorConditionFormula>
    <errorDisplayField>ATV_NTS_TRANSPORTE__c</errorDisplayField>
    <errorMessage>Para aceptar la cotización, completá: Transporte.</errorMessage>
</ValidationRule>
